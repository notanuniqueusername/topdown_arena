*.opensdf
*.opendb
*.sdf

# =========================================
# Unreal Engine 5 + Rider/VS Full Gitignore
# =========================================

# ----------------------------
# IDE / Editor files (Rider & VS)
# ----------------------------
.idea/
.shelf/
*.iml
out/
cmake-build-*/

# Visual Studio user-specific files
.vs/
.vscode
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
.vsconfig

# ----------------------------
# Compiled files / Binaries
# ----------------------------
# Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Dynamic libraries (Engine & Project)
*.so
*.dylib
*.dll

# Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa
*.target

# ----------------------------
# Unreal Engine Generated Folders
# ----------------------------
# Main generated folders
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Local data and logs
DataCache/
FileOpenOrder/
script/
*.log

# Built data for maps (Lightmaps/Navigation)
# Note: Keep these if you don't use a build server, but usually they are regenerated
*_BuiltData.uasset

# ----------------------------
# Project System Files
# ----------------------------
# These are regenerated by right-clicking the .uproject file
*.xcodeproj
*.xcworkspace
*.sln
*.vcxproj
*.filters

# ----------------------------
# Assets & Source Control
# ----------------------------
# Precompiled assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Ignore specific local collections
Collections/

# ----------------------------
# Whitelist (Do NOT ignore these)
# ----------------------------
# Ensure specific Build files stay in the repo
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# ----------------------------
# Common OS Files
# ----------------------------
.DS_Store
Thumbs.db
